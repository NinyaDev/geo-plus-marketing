# ──────────────────────────────────────────────
# Telegram Bot Configuration
# ──────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram (/newbot command)
TELEGRAM_BOT_TOKEN=

# Webhook secret for validating incoming requests
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Your public deployment URL (Vercel, ngrok, etc.)
# Example: https://geo-plus-marketing.vercel.app
TELEGRAM_WEBHOOK_URL=

# ──────────────────────────────────────────────
# Anthropic (Claude Sonnet 4.6 — main agent brain)
# ──────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# Supabase (persistence layer)
# ──────────────────────────────────────────────
# Create project at https://supabase.com → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
# xAI / Grok (research & scraping intelligence)
# ──────────────────────────────────────────────
# Get from: https://console.x.ai → API Keys
XAI_API_KEY=

# ──────────────────────────────────────────────
# Google / Gemini (Nano Banana Pro 2 — image gen)
# ──────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ──────────────────────────────────────────────
# GoHighLevel (CRM — lead sync)
# ──────────────────────────────────────────────
# PIT: GHL Settings → Business Profile → Integrations → Private Integrations
# Location ID: GHL Settings → Business Profile (in URL or Company tab)
GHL_PIT=
GHL_LOCATION_ID=

# ──────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────
TAVILY_API_KEY=
GPT_RESEARCHER_URL=http://localhost:8000
