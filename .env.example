# ──────────────────────────────────────────────
# Telegram Bot Configuration
# ──────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram (/newbot command)
TELEGRAM_BOT_TOKEN=

# Webhook secret for validating incoming requests
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Your public deployment URL (Vercel, ngrok, etc.)
# Example: https://geo-plus-marketing.vercel.app
TELEGRAM_WEBHOOK_URL=

# ──────────────────────────────────────────────
# OpenAI (GPT-4o for content generation)
# ──────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Supabase (persistence layer)
# ──────────────────────────────────────────────
# Create project at https://supabase.com → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────
# xAI / Grok (research & scraping intelligence)
# ──────────────────────────────────────────────
# Get from: https://console.x.ai → API Keys
XAI_API_KEY=

# ──────────────────────────────────────────────
# Google / Gemini (Nano Banana Pro 2 — image gen)
# ──────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ──────────────────────────────────────────────
# GPT Researcher (Python sidecar — optional)
# ──────────────────────────────────────────────
# Get from: https://tavily.com → API key
TAVILY_API_KEY=
GPT_RESEARCHER_URL=http://localhost:8000

# ──────────────────────────────────────────────
# MCP Servers (optional — Phase 4)
# ──────────────────────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_KEY=
# GSC_PROPERTY_URL=
# GBP_CLIENT_ID=
# GBP_CLIENT_SECRET=
# GBP_REFRESH_TOKEN=
